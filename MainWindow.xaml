<Window x:Class="BatchLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BatchLauncher"
        mc:Ignorable="d"
        MinWidth="550" 
        Title="MainWindow" Height="411" Width="775">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="4" Rows="1" 
                     HorizontalAlignment="Stretch"
                     Margin="0,0,0,5">
                    <Button x:Name="btnAddSoftware" Content="➕ 添加软件" 
                    MinWidth="90" Height="30" 
                    Click="AddSoftware_Click" Margin="5"/>
                    <Button x:Name="btnStartSelected" Content="▶ 启动选中" 
                    MinWidth="90" Height="30" 
                    Click="StartSelected_Click" Margin="5"/>
                    <Button x:Name="btnStartAll" Content="★ 启动全部" 
                    MinWidth="90" Height="30" 
                    Click="StartAll_Click" Margin="5"/>
                    <Button x:Name="btnRemoveSelected" Content="✖ 删除选中" 
                    MinWidth="90" Height="30" 
                    Click="RemoveSelected_Click" Margin="5"/>
                </UniformGrid>

                <CheckBox x:Name="chkSelectAll" Grid.Row="1" 
                  Content="全选" 
                  HorizontalAlignment="Right"
                  Margin="0,5,0,0"
                  Click="SelectAll_Click"/>
            </Grid>
        </Border>

        <!-- 软件列表 -->
        <ListView x:Name="lstSoftware" Grid.Row="1" Margin="0,0,0,10" SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="软件名称" Width="200" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="路径" Width="400" DisplayMemberBinding="{Binding Path}"/>
                    <GridViewColumn Header="参数" Width="120" DisplayMemberBinding="{Binding Arguments}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="2" Background="#F5F5F5">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
